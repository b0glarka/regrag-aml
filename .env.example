# Environment variables for RegRAG-AML.
# Copy this file to `.env` and fill in the keys you need. `.env` is gitignored.
#
# Embeddings run locally via sentence-transformers, so no embedding API key is
# required. You only need a key for answer generation and for the judge.

# Together AI API key. Default generator: Llama 3.3 70B Instruct Turbo.
# Chosen as the default because it is reliable for structured / cited output;
# see the README note on OpenRouter's structured-output routing.
# Used by: the LLMClient "together" provider.
TOGETHER_API_KEY=

# Anthropic API key. Faithfulness judge: Haiku 4.5 with a versioned rubric.
# Used by: the evaluation harness (answer-quality / citation faithfulness).
ANTHROPIC_API_KEY=

# OpenRouter API key. OPTIONAL alternate generator provider (one
# OpenAI-compatible endpoint to many models). Not the default for cited output.
# Used by: the LLMClient "openrouter" provider.
OPENROUTER_API_KEY=
